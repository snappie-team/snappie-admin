APP_NAME=laravel
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=single
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info
LOG_DAILY_DAYS=14

DB_CONNECTION=
DB_HOST=
DB_PORT=
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=60
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

CACHE_STORE=file
CACHE_PREFIX=snappie_admin_cache_
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
DB_QUEUE_TABLE=jobs
DB_QUEUE_RETRY_AFTER=90
QUEUE_FAILED_DRIVER=database-uuids

VITE_APP_NAME="${APP_NAME}"

ADMIN_NAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=
CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_VERSION=

# Health Check
HEALTH_CHECK_ENABLED=true

# Rate Limit Settings
# Auth (login/register): 5 requests per 60 seconds
RATE_LIMIT_AUTH=5
RATE_LIMIT_AUTH_DECAY=60
# Gamification (checkin/review): 10 requests per hour
RATE_LIMIT_GAMIFICATION=10
RATE_LIMIT_GAMIFICATION_DECAY=3600
# Social (posts/comment/like): 20 requests per 60 seconds
RATE_LIMIT_SOCIAL=20
RATE_LIMIT_SOCIAL_DECAY=60
# Default authenticated endpoints: 60 requests per 60 seconds
RATE_LIMIT_PRIVATE_DEFAULT=60
RATE_LIMIT_PRIVATE_DEFAULT_DECAY=60
# Public endpoints: 60 requests per 60 seconds
RATE_LIMIT_PUBLIC=60
RATE_LIMIT_PUBLIC_DECAY=60
# Laravel global API rate limit: 30 requests per minute
RATE_LIMIT_API=30